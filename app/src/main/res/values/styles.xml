<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="ShapeAppearance.Ticket.Small" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>

    <style name="ShapeAppearance.Ticket.Medium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">14dp</item>
    </style>

    <style name="ShapeAppearance.Ticket.Large" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="Widget.Ticket.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/card_corner</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="strokeWidth">@dimen/card_stroke</item>
        <item name="strokeColor">@color/outline_subtle</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <style name="Widget.Ticket.Card.Panel" parent="Widget.Ticket.Card">
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">@dimen/card_stroke</item>
    </style>

    <style name="TextAppearance.Ticket.ScreenTitle" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextAppearance.Ticket.ScreenSubtitle" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/on_surface_secondary</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextAppearance.Ticket.SectionLabel" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/on_surface_secondary</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="TextAppearance.Ticket.FieldLabel" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/on_surface_secondary</item>
        <item name="android:letterSpacing">0.03</item>
    </style>

    <style name="Widget.Ticket.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">@dimen/button_min_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:paddingLeft">20dp</item>
        <item name="android:paddingRight">20dp</item>
    </style>

    <style name="Widget.Ticket.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">@dimen/button_min_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="strokeColor">@color/outline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.Ticket.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="Widget.Ticket.Button.Compact.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">10dp</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="strokeColor">@color/outline</item>
    </style>

    <style name="Widget.Ticket.Button.Compact.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:minHeight">44dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Ticket.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
    </style>
</resources>

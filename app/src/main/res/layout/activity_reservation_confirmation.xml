<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/window_background"
    android:padding="@dimen/screen_padding_horizontal">

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.Ticket.Card.Panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardElevation="4dp"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.42"
        app:layout_constraintWidth_max="@dimen/content_max_width">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="@dimen/section_gap">

            <TextView
                style="@style/TextAppearance.Ticket.ScreenTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/confirmation_title" />

            <TextView
                android:id="@+id/confirm_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/block_gap"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:textAppearance="?attr/textAppearanceBody1"
                android:textColor="@color/on_surface" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_email_ticket"
                style="@style/Widget.Ticket.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/block_gap"
                android:text="@string/email_ticket" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_done"
                style="@style/Widget.Ticket.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/section_gap"
                android:text="@string/back_to_menu" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>
